generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model OnboardingApplication {
  id                                String             @id @default(cuid())
  organizationName                  String
  organizationType                  String
  contactName                       String
  contactEmail                      String
  contactPhone                      String?
  website                           String?
  status                            String
  finixIdentityId                   String?
  finixMerchantId                   String?
  submittedAt                       DateTime?
  approvedAt                        DateTime?
  rejectedAt                        DateTime?
  updateRequestedAt                 DateTime?
  updateReason                      String?
  finixOnboardingFormId             String?
  onboardingStatus                  String?
  verificationState                 String?
  lastFinixEventId                  String?
  lastFinixEventType                String?
  lastStatusChangedAt               DateTime?
  updateRequestedReason             String?
  updateRequestedItems              String?
  updateRequestedCodes              Json?
  rejectionReasonInternal           String?
  lastWebhookPayloadSummary         Json?
  updateTokenHash                   String?
  updateTokenExpiresAt              DateTime?
  lastUpdateSubmittedAt             DateTime?
  processingEnabled                 Boolean            @default(false)
  settlementEnabled                 Boolean            @default(false)
  createdAt                         DateTime           @default(now())
  updatedAt                         DateTime           @updatedAt
  achMaxTransactionAmountCents      Int?
  annualAchVolumeCents              Int?
  annualCardVolumeCents             Int?
  averageAchTransferAmountCents     Int?
  averageCardTransferAmountCents    Int?
  bankAccountType                   String?
  bankCountry                       String?
  bankCurrency                      String?
  bankInstrumentEnabled             Boolean            @default(false)
  bankInstrumentId                  String?
  bankLast4                         String?
  bankName                          String?
  businessAddressLine1              String?
  businessAddressLine2              String?
  businessCity                      String?
  businessCountry                   String?
  businessDescription               String?
  businessPhone                     String?
  businessPostalCode                String?
  businessState                     String?
  businessTaxIdProvided             Boolean            @default(false)
  businessToBusinessPercentage      Int?
  businessToConsumerPercentage      Int?
  businessType                      String?
  cardPresentPercentage             Int?
  defaultStatementDescriptor        String?
  doingBusinessAs                   String?
  ecommercePercentage               Int?
  finixApplicationId                String?
  finixPaymentInstrumentId          String?
  finixProcessor                    String?
  finixVerificationId               String?
  hasAcceptedCreditCardsPreviously  Boolean            @default(false)
  incorporationDay                  Int?
  incorporationMonth                Int?
  incorporationYear                 Int?
  legalBusinessName                 String?
  mailOrderTelephoneOrderPercentage Int?
  maxTransactionAmountCents         Int?
  mcc                               String?
  onboardingState                   String?
  otherVolumePercentage             Int?
  ownershipType                     String?
  principalAddressLine1             String?
  principalAddressLine2             String?
  principalCity                     String?
  principalCountry                  String?
  principalDobDay                   Int?
  principalDobMonth                 Int?
  principalDobYear                  Int?
  principalEmail                    String?
  principalFirstName                String?
  principalLastName                 String?
  principalOwnershipPercentage      Int?
  principalPhone                    String?
  principalPostalCode               String?
  principalState                    String?
  principalTaxIdProvided            Boolean            @default(false)
  principalTitle                    String?
  refundPolicy                      String?
  // TODO: Confirm exact Finix termination/suspension API and webhook event with Finix.
  // Placeholder fields only — no behavior implemented yet.
  terminationStatus                 String?
  terminatedAt                      DateTime?
  terminationReason                 String?
  suspendedAt                       DateTime?
  suspensionReason                  String?
  associatedOwners                  AssociatedOwner[]
  documents                         MerchantDocument[]
}

model AssociatedOwner {
  id                        String                @id @default(cuid())
  onboardingApplicationId   String
  finixAssociatedIdentityId String?
  firstName                 String
  lastName                  String
  title                     String?
  email                     String
  phone                     String?
  dobYear                   Int?
  dobMonth                  Int?
  dobDay                    Int?
  ownershipPercentage       Int?
  addressLine1              String?
  addressLine2              String?
  city                      String?
  state                     String?
  postalCode                String?
  country                   String?
  taxIdProvided             Boolean               @default(false)
  createdAt                 DateTime              @default(now())
  updatedAt                 DateTime              @updatedAt
  onboardingApplication     OnboardingApplication @relation(fields: [onboardingApplicationId], references: [id])
}

model LegalAcceptance {
  id                      String    @id @default(cuid())
  onboardingApplicationId String
  acceptedWgcTermsAt      DateTime?
  acceptedWgcFeesAt       DateTime?
  acceptedWgcPrivacyAt    DateTime?
  acceptedFinixTermsAt    DateTime?
  acceptedFinixPrivacyAt  DateTime?
  accepterName            String
  accepterEmail           String
  accepterIpAddress       String?
  accepterUserAgent       String?
  wgcTermsVersion         String
  wgcFeesVersion          String
  wgcPrivacyVersion       String
  finixTermsUrl           String
  finixPrivacyUrl         String
  source                  String
  createdAt               DateTime  @default(now())
}

model FinixWebhookEvent {
  id                String    @id @default(cuid())
  finixEventId      String    @unique
  entity            String?
  type              String
  occurredAt        DateTime?
  merchantId        String?
  identityId        String?
  verificationId    String?
  onboardingState   String?
  verificationState String?
  rawPayloadJson    Json
  processedAt       DateTime?
  processingStatus  String    @default("PENDING")
  errorMessage      String?
  createdAt         DateTime  @default(now())
}

model MerchantDocument {
  id                      String                @id @default(cuid())
  onboardingApplicationId String
  documentType            String
  fileName                String
  fileSize                Int
  mimeType                String
  uploadStatus            String
  finixFileId             String?
  uploadedBy              String
  createdAt               DateTime              @default(now())
  onboardingApplication   OnboardingApplication @relation(fields: [onboardingApplicationId], references: [id], onDelete: Cascade)
}

model EmailLog {
  id                      String    @id @default(cuid())
  onboardingApplicationId String?
  type                    String
  to                      String
  subject                 String
  status                  String
  providerMessageId       String?
  error                   String?
  sentAt                  DateTime?
  createdAt               DateTime  @default(now())
}

model AuditLog {
  id                      String   @id @default(cuid())
  onboardingApplicationId String?
  action                  String
  actorEmail              String?
  ipAddress               String?
  userAgent               String?
  metadata                Json?
  createdAt               DateTime @default(now())
}

model Church {
  id                            String   @id @default(cuid())
  name                          String
  slug                          String   @unique
  primaryContactEmail           String
  onboardingApplicationId       String?
  finixMerchantId               String?
  finixIdentityId               String?
  finixApplicationId            String?
  status                        String
  // Organization identity used on annual donation statements and the
  // organization profile — not required by onboarding/payments, so all
  // nullable. Intentionally not backfilled from OnboardingApplication:
  // Church.onboardingApplicationId isn't a dependable join, so these are
  // populated going forward via an explicit organization-profile edit.
  addressLine1                  String?
  addressLine2                  String?
  city                          String?
  state                         String?
  postalCode                    String?
  country                       String?
  logoUrl                       String?
  taxId                         String?
  phone                         String?
  // Year-End Donation Statement configuration (Settings -> Receipts &
  // Annual Statements). All optional — generation falls back to sensible
  // defaults (DEFAULT_THANK_YOU_MESSAGE, STATEMENT_DISCLAIMER) when unset.
  statementSenderName           String?
  statementReplyToEmail         String?
  statementSubjectTemplate      String?
  statementThankYouMessage      String?
  statementDisclaimer           String?
  statementShowDonorCoveredFees Boolean  @default(false)
  statementShowTaxId            Boolean  @default(false)
  createdAt                     DateTime @default(now())
  updatedAt                     DateTime @updatedAt
}

model Donor {
  id                  String    @id @default(cuid())
  churchId            String
  name                String?
  email               String?
  // Lowercased/trimmed copy of `email`, indexed for matching/dedup — `email`
  // itself stays exactly as entered for display.
  normalizedEmail     String?
  phone               String?
  // E.164-normalized copy of `phone` where the input is a recognizable US
  // number — `phone` itself stays exactly as entered for display.
  normalizedPhone     String?
  addressLine1        String?
  addressLine2        String?
  city                String?
  state               String?
  postalCode          String?
  country             String?
  companyName         String?
  // Donor-level display preference, distinct from Payment.isAnonymous
  // (a per-payment flag) — this is "always show this donor as anonymous."
  anonymousPreference Boolean   @default(false)
  finixIdentityId     String?   @unique
  archivedAt          DateTime?
  archivedByUserId    String?
  archivedByEmail     String?
  // Set when this donor record was merged into another (the survivor).
  // A merged donor is archived and never deleted — financial history stays
  // attached to it, so nothing here is ever hard-deleted.
  mergedIntoDonorId   String?
  mergedAt            DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([churchId])
  @@index([normalizedEmail])
  @@index([normalizedPhone])
  @@index([createdAt])
  @@index([archivedAt])
}

// Multiple free-text internal notes per donor, each with its own author/
// timestamp — distinct from the single-overwritable-field pattern used by
// FinixDispute.internalNote. Never sent to the donor or the processor.
model DonorNote {
  id              String    @id @default(cuid())
  donorId         String
  churchId        String
  body            String
  createdByUserId String?
  createdByEmail  String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  @@index([donorId])
  @@index([churchId])
}

// A named designation donations can be attributed to (e.g. "Building Fund",
// "General Fund"). Introduced to replace the free-text fundName strings on
// Payment/PaymentAttempt/GivingLink with a real per-organization entity —
// fundName itself is left in place on those models for backward
// compatibility; fundId is the new relationship going forward.
model Fund {
  id          String   @id @default(cuid())
  churchId    String
  name        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([churchId, name])
  @@index([churchId])
}

model Payment {
  id                         String    @id @default(cuid())
  churchId                   String
  donorId                    String?
  givingPageId               String?
  givingLinkId               String?
  finixTransferId            String?
  finixBuyerIdentityId       String?
  finixPaymentInstrumentId   String?
  amountCents                Int
  donationAmountCents        Int?
  feeCoveredCents            Int?
  currency                   String    @default("USD")
  paymentMethodType          String
  status                     String
  failureCode                String?
  failureMessage             String?
  failedAt                   DateTime?
  idempotencyId              String?
  fraudSessionId             String?
  receiptStatus              String?
  receiptSentAt              DateTime?
  achAuthorizationAccepted   Boolean   @default(false)
  achAuthorizationAcceptedAt DateTime?
  fundName                   String?
  fundId                     String?
  note                       String?
  isAnonymous                Boolean   @default(false)
  createdByAdminUserId       String?
  paymentAttemptId           String?
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt
}

// A payment attempt initiated by a church admin from the dashboard's "Take
// a Payment" flow, tracked from before the Finix API call is made so a
// browser retry / double-click / refresh can be recognized as the same
// logical attempt instead of minting a second charge. clientAttemptId is
// the stable key the frontend keeps across its own retries of one
// submission (a genuinely new attempt, e.g. hitting Retry after a failure,
// gets a fresh one). idempotencyId is generated here server-side exactly
// once per clientAttemptId and is the value actually sent to Finix.
model PaymentAttempt {
  id                String   @id @default(cuid())
  churchId          String
  adminUserId       String?
  donorId           String?
  givingLinkId      String?
  clientAttemptId   String   @unique
  idempotencyId     String   @unique
  amountCents       Int
  feeCents          Int?
  totalCents        Int
  paymentMethodType String
  fundName          String?
  fundId            String?
  note              String?
  isAnonymous       Boolean  @default(false)
  fraudSessionId    String?
  status            String // PROCESSING | PENDING | SUCCEEDED | FAILED | CANCELED
  finixTransferId   String?
  failureMessage    String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model SubscriptionPlan {
  id              String   @id @default(cuid())
  name            String
  description     String?
  amountCents     Int
  currency        String   @default("USD")
  billingInterval String
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model ChurchSubscription {
  id                       String    @id @default(cuid())
  onboardingApplicationId  String?
  churchId                 String?
  subscriptionPlanId       String
  finixSubscriptionId      String?
  finixBuyerIdentityId     String?
  finixPaymentInstrumentId String?
  amountCents              Int
  currency                 String    @default("USD")
  billingInterval          String
  state                    String
  subscriptionPhase        String?
  firstChargeAt            DateTime?
  nextBillingDate          DateTime?
  startedAt                DateTime?
  canceledAt               DateTime?
  expiresAt                DateTime?
  failedAt                 DateTime?
  failureCode              String?
  failureMessage           String?
  paymentMethodType        String?
  cardBrand                String?
  cardLast4                String?
  bankLast4                String?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt
  lastSyncedAt             DateTime?
}

model SubscriptionCharge {
  id                   String    @id @default(cuid())
  churchSubscriptionId String
  finixTransferId      String?
  amountCents          Int
  status               String
  paidAt               DateTime?
  failedAt             DateTime?
  failureCode          String?
  failureMessage       String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
}

// =========================================================================
// Finix data sync layer (additive only — see /docs or PR description for plan)
// TODO: Confirm exact Finix termination/suspension API and webhook event with Finix.
// =========================================================================

model FinixMerchantSnapshot {
  id                 String    @id @default(cuid())
  churchId           String?
  finixIdentityId    String?
  finixMerchantId    String    @unique
  finixApplicationId String?
  finixProcessor     String?
  onboardingState    String?
  merchantState      String?
  processingEnabled  Boolean   @default(false)
  settlementEnabled  Boolean   @default(false)
  verificationState  String?
  riskState          String?
  payoutProfileId    String?
  merchantProfileId  String?
  feeProfileId       String?
  terminationStatus  String?
  terminatedAt       DateTime?
  terminationReason  String?
  suspendedAt        DateTime?
  suspensionReason   String?
  rawStateRedacted   Json?
  lastSyncedAt       DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

model FinixTransfer {
  id                       String    @id @default(cuid())
  churchId                 String?
  paymentId                String?
  finixTransferId          String    @unique
  finixMerchantId          String?
  finixBuyerIdentityId     String?
  finixPaymentInstrumentId String?
  finixSettlementId        String?
  type                     String?
  subtype                  String?
  state                    String?
  amountCents              Int?
  currency                 String?
  feeCents                 Int?
  applicationFeeCents      Int?
  failureCode              String?
  failureMessage           String?
  traceId                  String?
  statementDescriptor      String?
  source                   String? // "wgc_giving_page" | "finix_dashboard" | "unknown"
  // Finix's own reported origin — confirmed real values include "SUBSCRIPTION",
  // "PAYMENT_LINK", "VIRTUAL_TERMINAL", "UNKNOWN". This is the authoritative
  // signal for "was this transfer a recurring-donation billing charge,"
  // rather than inferring it from whether the payment instrument merely has
  // a subscription attached (which a one-time gift on the same card would
  // also match).
  createdVia               String?
  tagsJson                 Json?
  rawJsonRedacted          Json?
  createdAtFinix           DateTime?
  updatedAtFinix           DateTime?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt
  lastSyncedAt             DateTime?
}

model FinixRefundOrReversal {
  id                      String    @id @default(cuid())
  churchId                String?
  refundRequestId         String?
  originalPaymentId       String?
  finixReversalId         String    @unique
  finixOriginalTransferId String?
  finixMerchantId         String?
  finixSettlementId       String?
  amountCents             Int?
  currency                String?
  state                   String?
  reason                  String?
  failureCode             String?
  failureMessage          String?
  type                    String?
  subtype                 String?
  source                  String?
  traceId                 String?
  tagsJson                Json?
  rawJsonRedacted         Json?
  createdAtFinix          DateTime?
  updatedAtFinix          DateTime?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
  lastSyncedAt            DateTime?
}

// A real ACH return (NACHA reason code), distinct from FinixRefundOrReversal
// (merchant-initiated refunds). Finix represents a return as a Transfer of
// subtype containing "RETURN" linked back to the original debit — this table
// gives it a first-class identity instead of relying on that heuristic at
// every read site.
model BankReturn {
  id                       String    @id @default(cuid())
  bankReturnId             String    @unique
  originalTransferId       String?
  churchId                 String?
  finixMerchantId          String?
  buyerId                  String?
  finixPaymentInstrumentId String?
  amountCents              Int?
  currency                 String?
  reasonCode               String?
  reasonDescription        String?
  state                    String?
  traceId                  String?
  effectiveAt              DateTime?
  rawPayloadRedacted       Json?
  createdAtFinix           DateTime?
  updatedAtFinix           DateTime?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt
  lastSyncedAt             DateTime?
}

model FinixFee {
  id              String    @id @default(cuid())
  churchId        String?
  finixFeeId      String?   @unique
  linkedToId      String?
  linkedToType    String?
  feeType         String?
  // Float, not Int: confirmed against a real Finix fee response that
  // basis-point-derived fees (e.g. CARD_BASIS_POINTS) come back with
  // fractional cents (e.g. 62.544) — an Int column silently rejected
  // these writes, which is why fee sync was failing for every payment.
  amountCents     Float?
  currency        String?
  state           String?
  description     String?
  rawJsonRedacted Json?
  createdAtFinix  DateTime?
  updatedAtFinix  DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model FinixSettlement {
  id                         String    @id @default(cuid())
  churchId                   String?
  finixSettlementId          String    @unique
  finixMerchantId            String?
  state                      String? // legacy: historically the raw "status" value — left as-is for backward compat
  processorState             String? // raw processor state as returned by every sync, never overwritten by a mapped value
  totalAmountCents           Int? // gross amount
  netAmountCents             Int? // processor-reported net
  feeAmountCents             Int?
  refundAmountCents          Int?
  returnAmountCents          Int? // bank returns against payments in this settlement
  disputeAmountCents         Int?
  otherAdjustmentAmountCents Int?
  transactionCount           Int?
  feeCount                   Int?
  refundCount                Int?
  bankReturnCount            Int?
  disputeCount               Int?
  traceId                    String?
  currency                   String?
  accruedAt                  DateTime?
  settledAt                  DateTime?
  createdAtFinix             DateTime?
  updatedAtFinix             DateTime?
  rawJsonRedacted            Json?
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt
  lastSyncedAt               DateTime?

  // Admin-controlled reconciliation state — never auto-set. The "calculated
  // net" vs "processor net" comparison itself is computed fresh on every
  // read from the settlement's actual included records, not stored here
  // (so it can't drift out of sync with the real numbers); this only
  // persists the human decision once a wgc_admin acts on it.
  reconciliationStatus String    @default("UNRECONCILED")
  reconciledAt         DateTime?
  reconciledByUserId   String?
  reconciledByEmail    String?
  reconciliationNotes  String?

  @@index([churchId])
  @@index([churchId, createdAtFinix])
}

model FinixFundingTransferAttempt {
  id                            String    @id @default(cuid())
  churchId                      String?
  finixFundingTransferAttemptId String    @unique
  finixSettlementId             String?
  finixMerchantId               String?
  state                         String?
  amountCents                   Int?
  netAmountCents                Int?
  currency                      String?
  fundingSpeed                  String? // NEXT_DAY | SAME_DAY | STANDARD | EXPRESS
  settlementCount               Int?
  paymentCount                  Int?
  bankAccountLast4              String?
  bankAccountType               String?
  bankName                      String?
  accountHolderName             String?
  failureCode                   String?
  failureMessage                String?
  traceId                       String?
  estimatedArrivalDate          DateTime?
  sentAt                        DateTime?
  arrivedAt                     DateTime?
  rawJsonRedacted               Json?
  createdAtFinix                DateTime?
  updatedAtFinix                DateTime?
  createdAt                     DateTime  @default(now())
  updatedAt                     DateTime  @updatedAt
  lastSyncedAt                  DateTime?
}

model FinixDispute {
  id                    String            @id @default(cuid())
  churchId              String?
  finixDisputeId        String            @unique
  finixTransferId       String?
  paymentId             String?
  finixMerchantId       String?
  state                 String? // legacy: historically the mapped display value — left as-is for backward compat with existing readers/filters
  processorState        String? // raw processor state as returned by every sync, never overwritten by a mapped value
  reason                String?
  amountCents           Int?
  currency              String?
  evidenceDueAt         DateTime?
  respondedAt           DateTime?
  resolvedAt            DateTime?
  outcome               String?
  // Submission failure/retry tracking: keep uploaded evidence and let the
  // admin retry final submission without re-uploading if it fails.
  submissionError       String?
  submissionAttemptedAt DateTime?
  submissionRetryCount  Int               @default(0)
  internalNote          String?
  rawJsonRedacted       Json?
  createdAtFinix        DateTime?
  updatedAtFinix        DateTime?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  lastSyncedAt          DateTime?
  evidence              DisputeEvidence[]

  @@index([churchId])
  @@index([evidenceDueAt])
}

// Metadata-only record of a dispute-evidence upload — the actual file bytes
// live in the processor (POST /disputes/{id}/evidence), never stored here.
// Deletion is soft (deletedAt) so audit-log rows referencing an evidenceId
// stay valid — the file is still gone from the admin's perspective (hidden
// everywhere, excluded from counts/allowance) without losing audit history.
model DisputeEvidence {
  id              String       @id @default(cuid())
  disputeId       String
  dispute         FinixDispute @relation(fields: [disputeId], references: [id])
  churchId        String?
  uploadedByEmail String?
  fileName        String
  fileSize        Int
  mimeType        String
  finixFileId     String?
  submittedAt     DateTime?
  deletedAt       DateTime?
  deletedByEmail  String?
  createdAt       DateTime     @default(now())

  @@index([disputeId])
  @@index([churchId])
}

// General-purpose dashboard action audit trail (distinct from the existing
// AuditLog, which is onboarding-flow-only). actorRole is a free string
// snapshotting whatever role the actor held at the time, not an FK — so
// this doesn't require adopting a wider role model to use.
model DashboardAuditLog {
  id          String   @id @default(cuid())
  churchId    String
  actorUserId String?
  actorEmail  String?
  actorRole   String?
  action      String
  entityType  String?
  entityId    String?
  metadata    Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  @@index([churchId, createdAt])
  @@index([entityType, entityId])
}

model FinixPaymentInstrumentSnapshot {
  id                       String    @id @default(cuid())
  churchId                 String?
  donorId                  String?
  finixPaymentInstrumentId String    @unique
  finixIdentityId          String?
  instrumentType           String?
  paymentMethodType        String?
  cardBrand                String?
  cardLast4                String?
  cardExpirationMonth      Int?
  cardExpirationYear       Int?
  bankLast4                String?
  bankAccountType          String?
  accountHolderName        String?
  state                    String?
  enabled                  Boolean?
  disabledCode             String?
  disabledMessage          String?
  securityCodeVerification String?
  addressVerification      String?
  issuerCountry            String?
  addressCountry           String?
  instrumentUse            String?
  rawJsonRedacted          Json?
  createdAtFinix           DateTime?
  updatedAtFinix           DateTime?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt
  lastSyncedAt             DateTime?
}

model FinixSubscription {
  id                       String    @id @default(cuid())
  churchId                 String?
  churchSubscriptionId     String?
  givingLinkId             String?
  finixSubscriptionId      String    @unique
  finixMerchantId          String?
  finixBuyerIdentityId     String?
  finixPaymentInstrumentId String?
  state                    String?
  amountCents              Int?
  currency                 String?
  billingInterval          String?
  collectionMethod         String?
  nextBillingDate          DateTime?
  startedAt                DateTime?
  canceledAt               DateTime?
  rawJsonRedacted          Json?
  createdAtFinix           DateTime?
  updatedAtFinix           DateTime?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt
  lastSyncedAt             DateTime?
}

model FinixSyncJob {
  id               String    @id @default(cuid())
  jobType          String
  churchId         String?
  finixMerchantId  String?
  status           String    @default("PENDING")
  startedAt        DateTime?
  completedAt      DateTime?
  failedAt         DateTime?
  errorMessage     String?
  recordsProcessed Int       @default(0)
  recordsCreated   Int       @default(0)
