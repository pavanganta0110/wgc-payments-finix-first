// A configurable, trackable donation link — distinct from the simpler
// GivingPage model below (which powers each church's one always-on default
// giving page). A GivingLink is created per-campaign, has its own lifecycle
// (active/inactive/expired/archived), amount rules, donor-field visibility,
// branding, and attempt/share tracking. Every Payment/PaymentAttempt/
// FinixSubscription created through one is tagged with its id for
// attribution (see givingLinkId fields above).
model GivingLink {
  id                        String    @id @default(cuid())
  churchId                  String
  publicSlug                String    @unique
  internalName              String
  publicTitle               String
  description               String?
  status                    String    @default("ACTIVE") // ACTIVE | INACTIVE | EXPIRED | ARCHIVED
  amountType                String    @default("FIXED") // FIXED | VARIABLE
  fixedAmountCents          Int?
  minAmountCents            Int?
  maxAmountCents            Int?
  suggestedAmountsJson      Json?
  allowCustomAmount         Boolean   @default(true)
  linkType                  String    @default("MULTI_USE") // ONE_TIME | MULTI_USE
  maxSuccessfulUses         Int?
  maxCollectedAmountCents   Int?
  expiresAt                 DateTime?
  fundName                  String?
  fundId                    String?
  recurringEnabled          Boolean   @default(false)
  allowedFrequenciesJson    Json?
  allowedPaymentMethodsJson Json? // ["CARD","BANK","APPLE_PAY","GOOGLE_PAY"]
  donorFieldSettingsJson    Json?
  feeCoverEnabled           Boolean   @default(true)
  feeCoverDefaultOn         Boolean   @default(true)
  receiptSettingsJson       Json?
  statementDescriptor       String?
  internalNote              String?
  referenceNumber           String?
  successReturnUrl          String?
  failureReturnUrl          String?
  cancelReturnUrl           String?
  brandingSettingsJson      Json?
  totalAttempts             Int       @default(0)
  successfulDonations       Int       @default(0)
  totalCollectedCents       Int       @default(0)
  refundedCents             Int       @default(0)
  returnedCents             Int       @default(0)
  lastUsedAt                DateTime?
  createdByUserId           String?
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt
}

model GivingLinkShare {
  id             String    @id @default(cuid())
  givingLinkId   String
  churchId       String
  sharedByUserId String?
  channel        String // COPY_LINK | QR_CODE | EMAIL | TEXT | MANUAL | EMBED
  recipient      String?
  message        String?
  state          String    @default("SENT") // SENT | FAILED | PENDING
  openedAt       DateTime?
  createdAt      DateTime  @default(now())
}

// One immutable snapshot per (donor, taxYear, version) — a later donor-name
// or organization-address change never alters a statement already
// generated/sent. Regenerating after a donation adjustment creates a new
// version and marks the previous one superseded rather than overwriting it.
model AnnualDonationStatement {
  id       String @id @default(cuid())
  churchId String
  donorId  String
  taxYear  Int
  version  Int    @default(1)

  statementStatus String @default("NOT_GENERATED") // NOT_GENERATED | NEEDS_REVIEW | READY | GENERATED | VOIDED
  deliveryStatus  String @default("NOT_SENT") // NOT_SENT | QUEUED | SENT | DELIVERED | BOUNCED | FAILED

  grossDonatedCents      Int @default(0)
  refundedAmountCents    Int @default(0)
  returnedAmountCents    Int @default(0)
  disputeAdjustmentCents Int @default(0)
  eligibleAmountCents    Int @default(0)
  donationCount          Int @default(0)

  // Snapshots — copied at generation time, never re-read live.
  donorNameSnapshot           String?
  donorEmailSnapshot          String?
  donorAddressSnapshot        Json?
  organizationNameSnapshot    String?
  organizationAddressSnapshot Json?
  organizationTaxIdSnapshot   String?

  pdfStorageReference     String?
  secureDownloadTokenHash String?
  secureDownloadExpiresAt DateTime?

  generatedByUserId String?
  generatedAt       DateTime?

  recipientEmail         String?
  emailProviderMessageId String?
  sentAt                 DateTime?
  deliveredAt            DateTime?
  bouncedAt              DateTime?
  failureReason          String?
  resendCount            Int       @default(0)

  supersededAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([donorId, taxYear, version])
  @@index([churchId])
  @@index([donorId])
  @@index([churchId, taxYear])
}

/// Background job for bulk statement generate/send. There is no persistent
/// worker process in this app (serverless, no queue infra) — the client
/// drives progress by repeatedly calling the "process one chunk" route while
/// status is PENDING/RUNNING, and each call advances processedCount by one
/// chunk. This is a real chunked-processing job (state lives in the DB and
/// survives a page reload), not a UI-only fake progress bar.
model BulkStatementJob {
  id       String @id @default(cuid())
  churchId String
  taxYear  Int
  jobType  String // GENERATE | SEND

  targetIds  Json // donorIds for GENERATE, statementIds for SEND
  totalCount Int

  status String @default("PENDING") // PENDING | RUNNING | COMPLETED | FAILED

  processedCount   Int @default(0)
  succeededCount   Int @default(0)
  failedCount      Int @default(0)
  needsReviewCount Int @default(0)
  skippedCount     Int @default(0)

  createdByUserId String?
  createdAt       DateTime  @default(now())
  completedAt     DateTime?

  @@index([churchId, status])
}

model AnnualDonationStatementLine {
  id                String  @id @default(cuid())
  annualStatementId String
  paymentId         String?

  donationDate       DateTime?
  reference          String?
  fundOrCampaignName String?

  grossAmountCents       Int @default(0)
  donorCoveredFeeCents   Int @default(0)
  refundedAmountCents    Int @default(0)
  returnedAmountCents    Int @default(0)
  disputeAdjustmentCents Int @default(0)
  eligibleAmountCents    Int @default(0)

  createdAt DateTime @default(now())

  @@index([annualStatementId])
}

