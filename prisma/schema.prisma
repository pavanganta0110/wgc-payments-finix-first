}

model FinixSubscription {
  id                         String    @id @default(cuid())
  churchId                   String?
  churchSubscriptionId       String?
  givingLinkId               String?
  fundId                     String?
  // Denormalized from FinixPaymentInstrumentSnapshot.donorId at webhook-sync
  // time — donor is only ever real-linked through the instrument, this
  // column exists purely so the Recurring Donors / Subscriptions list
  // queries can filter/sort/join by donor without an N+1 lookup per row.
  donorId                    String?
  finixSubscriptionId        String    @unique
  finixMerchantId            String?
  finixBuyerIdentityId       String?
  finixPaymentInstrumentId   String?
  // Raw processor state as reported by Finix (e.g. "ACTIVE", "CANCELED").
  // Display status (including MIXED/PAST_DUE/attention derivations across
  // a donor's multiple subscriptions) is always computed on read from this
  // plus related payment/instrument state — never stored redundantly.
  state                      String?
  amountCents                Int?
  currency                   String?
  billingInterval            String?
  collectionMethod           String?
  nextBillingDate            DateTime?
  startedAt                  DateTime?
  canceledAt                 DateTime?
  // Finix's subscriptions API (confirmed in src/lib/finix/client.ts) only
  // supports create/get/cancel — no pause/resume/update-in-place endpoint.
  // completedAt is set when Finix reports a finite subscription reaching
  // its natural end (not an admin action); cancelReason/canceledByUserId
  // distinguish a real admin-initiated cancellation from that.
  completedAt                DateTime?
  cancelReason               String?
  canceledByUserId           String?
  failureCode                String?
  failureMessage             String?
  retryCount                 Int?
  // "Update Amount"/"Update Frequency" have no in-place Finix endpoint, so
  // they're implemented as cancel-old + create-new. These two columns chain
  // that history so the UI can show "this subscription replaced/was
  // replaced by" instead of presenting two unrelated rows.
  supersedesSubscriptionId   String?
  supersededBySubscriptionId String?
  // Distinguishes an admin-created subscription (existing saved payment
  // method flow) from one created by a donor via the public giving page or
  // a secure setup link — never inferred, always set at creation time.
  createdByUserId            String?
  consentSource              String? // ADMIN_CONFIRMED | DONOR_DIRECT
  rawJsonRedacted            Json?
  createdAtFinix             DateTime?
  updatedAtFinix             DateTime?
  donationAmountCents        Int?
  donorCoversFee             Boolean?
  feeCalculationVersion      String?

  // Reconciliation/date-sync fields — see subscriptionReconciliation.ts.
  // lastBillingAt/lastSuccessfulChargeAt are set from an actually-observed
  // recurring charge (webhook or reconciled transfer), never inferred by
  // adding one interval to the previous date. nextBillingDate is only ever
  // trusted from Finix's own schedule response, never computed locally.
  lastBillingAt          DateTime?
  lastSuccessfulChargeAt DateTime?
  lastReconciledAt       DateTime?
  // True when donorId could not be resolved (directly or via the linked
  // payment instrument) and needs an authorized admin to manually pick the
  // correct donor — never auto-matched by name alone.
  needsDonorMatching     Boolean   @default(false)

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  lastSyncedAt DateTime?

  @@index([churchId, donorId])
  @@index([churchId, state])
}

/// Immutable record of donor authorization for a recurring donation —
/// created exactly once at subscription-creation time and never mutated
/// afterward, even if the subscription itself is later changed/canceled.
model SubscriptionConsent {
  id                            String   @id @default(cuid())
  churchId                      String
  donorId                       String
  finixSubscriptionId           String   @unique
  consentSource                 String // ADMIN_CONFIRMED | DONOR_DIRECT
  confirmedByUserId             String?
  acceptedAt                    DateTime @default(now())
  termsVersion                  String
  ipAddress                     String?
  userAgent                     String?
  setupLinkId                   String?
  recurringTermsSnapshot        Json
  donorNameSnapshot             String?
  donorEmailSnapshot            String?
  amountCentsSnapshot           Int
  frequencySnapshot             String
  startDateSnapshot             DateTime
  paymentMethodLastFourSnapshot String?
  organizationNameSnapshot      String?
  createdAt                     DateTime @default(now())

  @@index([churchId, donorId])
}

/// Secure, single-purpose, expiring token a donor uses to set up a new
/// recurring donation without an admin ever touching raw payment data.
/// Only tokenHash is stored — the raw token exists only in the emailed URL.
model SubscriptionSetupLink {
  id                              String    @id @default(cuid())
  churchId                        String
  donorId                         String? // null until an existing donor is matched/a new one is created on completion
  donorFirstName                  String?
  donorLastName                   String?
  donorEmail                      String
  donorPhone                      String?
  tokenHash                       String    @unique
  amountCents                     Int
  billingInterval                 String
  startDate                       DateTime
  endDate                         DateTime?
  fundId                          String?
  message                         String?
  status                          String    @default("PENDING") // PENDING | SENT | OPENED | COMPLETED | EXPIRED | REVOKED | FAILED
  finixSubscriptionId             String? // set once the donor completes setup
  // When set, this link is a "Send Payment Update Link" for an existing
  // subscription rather than a brand-new one — completion cancels this
  // subscription and creates a replacement with the new payment method
  // (see FinixSubscription.supersedesSubscriptionId), same terms otherwise.
  updateTargetFinixSubscriptionId String?
  expiresAt                       DateTime
  sentAt                          DateTime?
  deliveredAt                     DateTime?
  openedAt                        DateTime?
  completedAt                     DateTime?
  revokedAt                       DateTime?
  revokedByUserId                 String?
  failureReason                   String?
  createdByUserId                 String?
  createdAt                       DateTime  @default(now())
  updatedAt                       DateTime  @updatedAt

  @@index([churchId, status])
}

/// Audit + idempotency log for every subscription mutation (admin-initiated
/// or donor-initiated). idempotencyKey has a unique constraint so a
/// double-click or network retry can never apply the same action twice.
model SubscriptionAction {
  id                  String    @id @default(cuid())
  churchId            String
  finixSubscriptionId String
  actionType          String // CREATE | CANCEL | UPDATE_AMOUNT | UPDATE_FREQUENCY | SEND_PAYMENT_UPDATE_LINK | PAYMENT_METHOD_UPDATED
  idempotencyKey      String    @unique
  requestedByUserId   String?
  oldValue            Json?
  newValue            Json?
  state               String    @default("PENDING") // PENDING | COMPLETED | FAILED
  failureReason       String?
  createdAt           DateTime  @default(now())
  completedAt         DateTime?

  @@index([churchId, finixSubscriptionId])
}

model FinixSyncJob {
  id               String    @id @default(cuid())
  jobType          String
  churchId         String?
  finixMerchantId  String?
  status           String    @default("PENDING")
  startedAt        DateTime?
  completedAt      DateTime?
  failedAt         DateTime?
  errorMessage     String?
  recordsProcessed Int       @default(0)
  recordsCreated   Int       @default(0)
  recordsUpdated   Int       @default(0)
  cursor           String?
  dateFrom         DateTime?
  dateTo           DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model FinixRawEventArchive {
  id                  String    @id @default(cuid())
  finixEventId        String?   @unique
  entity              String?
  eventType           String?
  resourceId          String?
  churchId            String?
  finixMerchantId     String?
  payloadRedactedJson Json
  processedAt         DateTime?
  processingStatus    String    @default("PENDING")
  errorMessage        String?
  createdAt           DateTime  @default(now())
}

model MerchantStatusHistory {
  id             String   @id @default(cuid())
  churchId       String?
  previousStatus String?
  newStatus      String
  source         String?
  finixEventId   String?
  changedAt      DateTime @default(now())
  emailTriggered Boolean  @default(false)
  emailLogId     String?
  createdAt      DateTime @default(now())
}

model ReportSnapshot {
  id                     String   @id @default(cuid())
  churchId               String?
  reportType             String
  periodStart            DateTime
  periodEnd              DateTime
  grossVolumeCents       Int?
  netVolumeCents         Int?
  refundAmountCents      Int?
  feeAmountCents         Int?
  disputeAmountCents     Int?
  payoutAmountCents      Int?
  donorCount             Int?
  transactionCount       Int?
  failedTransactionCount Int?
  payloadJson            Json?
  generatedAt            DateTime @default(now())
  createdAt              DateTime @default(now())
}

// Minimal additive tables — not yet wired into existing refund/pricing business logic
model RefundRequest {
  id                String   @id @default(cuid())
  churchId          String?
  originalPaymentId String?
  requestedByEmail  String?
  amountCents       Int?
  reason            String?
  status            String   @default("PENDING")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model ChurchPricing {
  id                String   @id @default(cuid())
  churchId          String   @unique
  pricingPlanName   String?
  cardPercentageFee Float?
  cardFixedFeeCents Int?
  achFixedFeeCents  Int?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// Snapshot of a Finix Fee Profile (docs.finix.com/api/fee-profiles). Rates
// live entirely in Finix's dashboard — this table is a read-only cache kept
// in sync via fee_profile.created/updated webhooks, feeding ChurchPricing.
model FinixFeeProfile {
  id                String    @id @default(cuid())
  finixFeeProfileId String    @unique
  basisPoints       Int?
  fixedFeeCents     Int?
  achBasisPoints    Int?
  achFixedFeeCents  Int?
  rawJsonRedacted   Json?
  createdAtFinix    DateTime?
  updatedAtFinix    DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  lastSyncedAt      DateTime?
}

// Snapshot of a Finix Merchant Profile (docs.finix.com/api/merchant-profiles),
// which links a Merchant to its Fee Profile. Kept in sync via
// merchant_profile.created/updated webhooks.
model FinixMerchantProfile {
  id                     String    @id @default(cuid())
  finixMerchantProfileId String    @unique
  finixFeeProfileId      String?
  finixPayoutProfileId   String?
  finixRiskProfileId     String?
  rawJsonRedacted        Json?
  createdAtFinix         DateTime?
  updatedAtFinix         DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  lastSyncedAt           DateTime?
}

/// Observability only — records what GET /payout_profiles/{id} actually
/// returns for a church's merchant profile, so the real response shape can
/// be inspected before any write path is ever attempted against it. Not
/// used as a source of truth for activation until the shape is confirmed.
model FinixPayoutProfileSnapshot {
  id                   String    @id @default(cuid())
  churchId             String?
  finixPayoutProfileId String    @unique
  rawJsonRedacted      Json?
  createdAtFinix       DateTime?
  updatedAtFinix       DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  lastSyncedAt         DateTime?
}

model User {
  id                        String    @id @default(cuid())
  email                     String    @unique
  passwordHash              String?
  role                      String // "wgc_admin" | "church_admin"
  churchId                  String?
  setPasswordTokenHash      String?
  setPasswordTokenExpiresAt DateTime?
  lastLoginAt               DateTime?
  // Team & Access (Settings -> Team). A User with passwordHash null and a
  // live setPasswordTokenHash is "invited, pending" — the exact same
  // pattern already used by forgot-password, reused here rather than
  // inventing a separate invitation concept.
  invitedByUserId           String?
  disabledAt                DateTime?
  disabledByUserId          String?
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt
}

model FinixAuthorization {
  id                       String    @id @default(cuid())
  churchId                 String?
  finixAuthorizationId     String    @unique
  finixMerchantId          String?
  finixTransferId          String?
  finixPaymentInstrumentId String?
  finixBuyerIdentityId     String?
  state                    String?
  amountCents              Int?
  amountRequestedCents     Int?
  currency                 String?
  failureCode              String?
  failureMessage           String?
  isVoid                   Boolean?
  voidState                String?
  voidedAt                 DateTime?
  expiresAt                DateTime?
  authorizationCode        String?
  traceId                  String?
  cvvVerification          String?
  addressVerification      String?
  tagsJson                 Json?
  rawJsonRedacted          Json?
  createdAtFinix           DateTime?
  updatedAtFinix           DateTime?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt
  lastSyncedAt             DateTime?
}

// A configurable, trackable donation link — distinct from the simpler
// GivingPage model below (which powers each church's one always-on default
// giving page). A GivingLink is created per-campaign, has its own lifecycle
// (active/inactive/expired/archived), amount rules, donor-field visibility,
// branding, and attempt/share tracking. Every Payment/PaymentAttempt/
// FinixSubscription created through one is tagged with its id for
// attribution (see givingLinkId fields above).
model GivingLink {
  id                        String    @id @default(cuid())
  churchId                  String
  publicSlug                String    @unique
  internalName              String
  publicTitle               String
  description               String?
  status                    String    @default("ACTIVE") // ACTIVE | INACTIVE | EXPIRED | ARCHIVED
  amountType                String    @default("FIXED") // FIXED | VARIABLE
  fixedAmountCents          Int?
  minAmountCents            Int?
  maxAmountCents            Int?
  suggestedAmountsJson      Json?
  allowCustomAmount         Boolean   @default(true)
  linkType                  String    @default("MULTI_USE") // ONE_TIME | MULTI_USE
  maxSuccessfulUses         Int?
  maxCollectedAmountCents   Int?
  expiresAt                 DateTime?
  fundName                  String?
  fundId                    String?
  recurringEnabled          Boolean   @default(false)
  allowedFrequenciesJson    Json?
  allowedPaymentMethodsJson Json? // ["CARD","BANK","APPLE_PAY","GOOGLE_PAY"]
  donorFieldSettingsJson    Json?
  feeCoverEnabled           Boolean   @default(true)
  feeCoverDefaultOn         Boolean   @default(true)
  receiptSettingsJson       Json?
  statementDescriptor       String?
  internalNote              String?
  referenceNumber           String?
  successReturnUrl          String?
  failureReturnUrl          String?
  cancelReturnUrl           String?
  brandingSettingsJson      Json?
  totalAttempts             Int       @default(0)
  successfulDonations       Int       @default(0)
  totalCollectedCents       Int       @default(0)
  refundedCents             Int       @default(0)
  returnedCents             Int       @default(0)
  lastUsedAt                DateTime?
  createdByUserId           String?
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt
}

model GivingLinkShare {
  id             String    @id @default(cuid())
  givingLinkId   String
  churchId       String
  sharedByUserId String?
  channel        String // COPY_LINK | QR_CODE | EMAIL | TEXT | MANUAL | EMBED
  recipient      String?
  message        String?
  state          String    @default("SENT") // SENT | FAILED | PENDING
  openedAt       DateTime?
  createdAt      DateTime  @default(now())
}

// One immutable snapshot per (donor, taxYear, version) — a later donor-name
// or organization-address change never alters a statement already
// generated/sent. Regenerating after a donation adjustment creates a new
// version and marks the previous one superseded rather than overwriting it.
model AnnualDonationStatement {
  id       String @id @default(cuid())
  churchId String
  donorId  String
  taxYear  Int
  version  Int    @default(1)

  statementStatus String @default("NOT_GENERATED") // NOT_GENERATED | NEEDS_REVIEW | READY | GENERATED | VOIDED
  deliveryStatus  String @default("NOT_SENT") // NOT_SENT | QUEUED | SENT | DELIVERED | BOUNCED | FAILED

  grossDonatedCents      Int @default(0)
  refundedAmountCents    Int @default(0)
  returnedAmountCents    Int @default(0)
  disputeAdjustmentCents Int @default(0)
  eligibleAmountCents    Int @default(0)
  donationCount          Int @default(0)

  // Snapshots — copied at generation time, never re-read live.
  donorNameSnapshot           String?
  donorEmailSnapshot          String?
  donorAddressSnapshot        Json?
  organizationNameSnapshot    String?
  organizationAddressSnapshot Json?
  organizationTaxIdSnapshot   String?

  pdfStorageReference     String?
  secureDownloadTokenHash String?
  secureDownloadExpiresAt DateTime?

  generatedByUserId String?
  generatedAt       DateTime?

  recipientEmail         String?
  emailProviderMessageId String?
  sentAt                 DateTime?
  deliveredAt            DateTime?
  bouncedAt              DateTime?
  failureReason          String?
  resendCount            Int       @default(0)

  supersededAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([donorId, taxYear, version])
  @@index([churchId])
  @@index([donorId])
  @@index([churchId, taxYear])
}

/// Background job for bulk statement generate/send. There is no persistent
/// worker process in this app (serverless, no queue infra) — the client
/// drives progress by repeatedly calling the "process one chunk" route while
/// status is PENDING/RUNNING, and each call advances processedCount by one
/// chunk. This is a real chunked-processing job (state lives in the DB and
/// survives a page reload), not a UI-only fake progress bar.
model BulkStatementJob {
  id       String @id @default(cuid())
  churchId String
  taxYear  Int
  jobType  String // GENERATE | SEND

  targetIds  Json // donorIds for GENERATE, statementIds for SEND
  totalCount Int

  status String @default("PENDING") // PENDING | RUNNING | COMPLETED | FAILED

  processedCount   Int @default(0)
  succeededCount   Int @default(0)
  failedCount      Int @default(0)
  needsReviewCount Int @default(0)
  skippedCount     Int @default(0)

  createdByUserId String?
  createdAt       DateTime  @default(now())
  completedAt     DateTime?

  @@index([churchId, status])
}

model AnnualDonationStatementLine {
  id                String  @id @default(cuid())
  annualStatementId String
  paymentId         String?

  donationDate       DateTime?
  reference          String?
  fundOrCampaignName String?

  grossAmountCents       Int @default(0)
  donorCoveredFeeCents   Int @default(0)
  refundedAmountCents    Int @default(0)
  returnedAmountCents    Int @default(0)
  disputeAdjustmentCents Int @default(0)
  eligibleAmountCents    Int @default(0)

  // Snapshotted from the Payment's goods/services fields at generation
  // time, per line — a statement immutably reflects what each individual
  // contribution actually disclosed, not a live re-read.
  goodsServicesProvided             Boolean @default(false)
  goodsServicesDescription          String?
  goodsServicesFairMarketValueCents Int?
  recordedContributionAmountCents   Int?

  createdAt DateTime @default(now())

  @@index([annualStatementId])
}
