  uploadedByEmail String?
  fileName        String
  fileSize        Int
  mimeType        String
  finixFileId     String?
  submittedAt     DateTime?
  deletedAt       DateTime?
  deletedByEmail  String?
  createdAt       DateTime     @default(now())

  @@index([disputeId])
  @@index([churchId])
}

// General-purpose dashboard action audit trail (distinct from the existing
// AuditLog, which is onboarding-flow-only). actorRole is a free string
