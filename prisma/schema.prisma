generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model OnboardingApplication {
  id                                String            @id @default(cuid())
  organizationName                  String
  organizationType                  String
  contactName                       String
  contactEmail                      String
  contactPhone                      String?
  website                           String?
  status                            String
  finixIdentityId                   String?
  finixMerchantId                   String?
  submittedAt                       DateTime?
  approvedAt                        DateTime?
  rejectedAt                        DateTime?
  updateRequestedAt                 DateTime?
  updateReason                      String?
  finixOnboardingFormId             String?
  onboardingStatus                  String?
  verificationState                 String?
  lastFinixEventId                  String?
  lastFinixEventType                String?
  lastStatusChangedAt               DateTime?
  updateRequestedReason             String?
  updateRequestedItems              String?
  updateRequestedCodes              Json?
  rejectionReasonInternal           String?
  lastWebhookPayloadSummary         Json?
  updateTokenHash                   String?
  updateTokenExpiresAt              DateTime?
  lastUpdateSubmittedAt             DateTime?
  processingEnabled                 Boolean           @default(false)
  settlementEnabled                 Boolean           @default(false)
  createdAt                         DateTime          @default(now())
  updatedAt                         DateTime          @updatedAt
  achMaxTransactionAmountCents      Int?
  annualAchVolumeCents              Int?
  annualCardVolumeCents             Int?
  averageAchTransferAmountCents     Int?
  averageCardTransferAmountCents    Int?
  bankAccountType                   String?
  bankCountry                       String?
  bankCurrency                      String?
  bankInstrumentEnabled             Boolean           @default(false)
  bankInstrumentId                  String?
  bankLast4                         String?
  bankName                          String?
  businessAddressLine1              String?
  businessAddressLine2              String?
  businessCity                      String?
  businessCountry                   String?
  businessDescription               String?
  businessPhone                     String?
  businessPostalCode                String?
  businessState                     String?
  businessTaxIdProvided             Boolean           @default(false)
  businessToBusinessPercentage      Int?
  businessToConsumerPercentage      Int?
  businessType                      String?
  cardPresentPercentage             Int?
  defaultStatementDescriptor        String?
  doingBusinessAs                   String?
  ecommercePercentage               Int?
  finixApplicationId                String?
  finixPaymentInstrumentId          String?
  finixProcessor                    String?
  finixVerificationId               String?
  hasAcceptedCreditCardsPreviously  Boolean           @default(false)
  incorporationDay                  Int?
  incorporationMonth                Int?
  incorporationYear                 Int?
  legalBusinessName                 String?
  mailOrderTelephoneOrderPercentage Int?
  maxTransactionAmountCents         Int?
  mcc                               String?
  onboardingState                   String?
  otherVolumePercentage             Int?
  ownershipType                     String?
  principalAddressLine1             String?
  principalAddressLine2             String?
  principalCity                     String?
  principalCountry                  String?
  principalDobDay                   Int?
  principalDobMonth                 Int?
  principalDobYear                  Int?
  principalEmail                    String?
  principalFirstName                String?
  principalLastName                 String?
  principalOwnershipPercentage      Int?
  principalPhone                    String?
  principalPostalCode               String?
  principalState                    String?
  principalTaxIdProvided            Boolean           @default(false)
  principalTitle                    String?
  refundPolicy                      String?
  associatedOwners                  AssociatedOwner[]
  documents                         MerchantDocument[]
}

model AssociatedOwner {
  id                        String                @id @default(cuid())
  onboardingApplicationId   String
  finixAssociatedIdentityId String?
  firstName                 String
  lastName                  String
  title                     String?
  email                     String
  phone                     String?
  dobYear                   Int?
  dobMonth                  Int?
  dobDay                    Int?
  ownershipPercentage       Int?
  addressLine1              String?
  addressLine2              String?
  city                      String?
  state                     String?
  postalCode                String?
  country                   String?
  taxIdProvided             Boolean               @default(false)
  createdAt                 DateTime              @default(now())
  updatedAt                 DateTime              @updatedAt
  onboardingApplication     OnboardingApplication @relation(fields: [onboardingApplicationId], references: [id])
}

model LegalAcceptance {
  id                      String    @id @default(cuid())
  onboardingApplicationId String
  acceptedWgcTermsAt      DateTime?
  acceptedWgcFeesAt       DateTime?
  acceptedWgcPrivacyAt    DateTime?
  acceptedFinixTermsAt    DateTime?
  acceptedFinixPrivacyAt  DateTime?
  accepterName            String
  accepterEmail           String
  accepterIpAddress       String?
  accepterUserAgent       String?
  wgcTermsVersion         String
  wgcFeesVersion          String
  wgcPrivacyVersion       String
  finixTermsUrl           String
  finixPrivacyUrl         String
  source                  String
  createdAt               DateTime  @default(now())
}

model FinixWebhookEvent {
  id               String    @id @default(cuid())
  finixEventId     String    @unique
  entity           String?
  type             String
  occurredAt       DateTime?
  merchantId       String?
  identityId       String?
  verificationId   String?
  onboardingState  String?
  verificationState String?
  rawPayloadJson   Json
  processedAt      DateTime?
  processingStatus String    @default("PENDING")
  errorMessage     String?
  createdAt        DateTime  @default(now())
}

model MerchantDocument {
  id                      String                @id @default(cuid())
  onboardingApplicationId String
  documentType            String
  fileName                String
  fileSize                Int
  mimeType                String
  uploadStatus            String
  finixFileId             String?
  uploadedBy              String
  createdAt               DateTime              @default(now())
  onboardingApplication   OnboardingApplication @relation(fields: [onboardingApplicationId], references: [id], onDelete: Cascade)
}

model EmailLog {
  id                      String    @id @default(cuid())
  onboardingApplicationId String?
  type                    String
  to                      String
  subject                 String
  status                  String
  providerMessageId       String?
  error                   String?
  sentAt                  DateTime?
  createdAt               DateTime  @default(now())
}

model AuditLog {
  id                      String   @id @default(cuid())
  onboardingApplicationId String?
  action                  String
  actorEmail              String?
  ipAddress               String?
  userAgent               String?
  metadata                Json?
  createdAt               DateTime @default(now())
}

model Church {
  id                      String   @id @default(cuid())
  name                    String
  slug                    String   @unique
  primaryContactEmail     String
  onboardingApplicationId String?
  finixMerchantId         String?
  finixIdentityId         String?
  status                  String
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}

model Donor {
  id        String   @id @default(cuid())
  churchId  String
  name      String?
  email     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Payment {
  id                         String    @id @default(cuid())
  churchId                   String
  donorId                    String?
  finixTransferId            String?
  finixBuyerIdentityId       String?
  finixPaymentInstrumentId   String?
  amountCents                Int
  currency                   String    @default("USD")
  paymentMethodType          String
  status                     String
  failureCode                String?
  failureMessage             String?
  failedAt                   DateTime?
  idempotencyId              String?
  fraudSessionId             String?
  receiptStatus              String?
  receiptSentAt              DateTime?
  achAuthorizationAccepted   Boolean   @default(false)
  achAuthorizationAcceptedAt DateTime?
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt
}

model SubscriptionPlan {
  id              String   @id @default(cuid())
  name            String
  description     String?
  amountCents     Int
  currency        String   @default("USD")
  billingInterval String
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model ChurchSubscription {
  id                       String    @id @default(cuid())
  onboardingApplicationId  String?
  churchId                 String?
  subscriptionPlanId       String
  finixSubscriptionId      String?
  finixBuyerIdentityId     String?
  finixPaymentInstrumentId String?
  amountCents              Int
  currency                 String    @default("USD")
  billingInterval          String
  state                    String
  subscriptionPhase        String?
  firstChargeAt            DateTime?
  nextBillingDate          DateTime?
  startedAt                DateTime?
  canceledAt               DateTime?
  expiresAt                DateTime?
  failedAt                 DateTime?
  failureCode              String?
  failureMessage           String?
  paymentMethodType        String?
  cardBrand                String?
  cardLast4                String?
  bankLast4                String?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt
  lastSyncedAt             DateTime?
}

model SubscriptionCharge {
  id                   String    @id @default(cuid())
  churchSubscriptionId String
  finixTransferId      String?
  amountCents          Int
  status               String
  paidAt               DateTime?
  failedAt             DateTime?
  failureCode          String?
  failureMessage       String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
}
