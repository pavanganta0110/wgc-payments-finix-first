}

model FinixTransfer {
  id                       String    @id @default(cuid())
  churchId                 String?
  paymentId                String?
  finixTransferId          String    @unique
  finixMerchantId          String?
  finixBuyerIdentityId     String?
  finixPaymentInstrumentId String?
  finixSettlementId        String?
  type                     String?
  subtype                  String?
  state                    String?
  amountCents              Int?
  currency                 String?
  feeCents                 Int?
  applicationFeeCents      Int?
  failureCode              String?
  failureMessage           String?
  traceId                  String?
  statementDescriptor      String?
  source                   String? // "wgc_giving_page" | "finix_dashboard" | "unknown"
  // Finix's own reported origin — confirmed real values include "SUBSCRIPTION",
  // "PAYMENT_LINK", "VIRTUAL_TERMINAL", "UNKNOWN". This is the authoritative
  // signal for "was this transfer a recurring-donation billing charge,"
  // rather than inferring it from whether the payment instrument merely has
  // a subscription attached (which a one-time gift on the same card would
  // also match).
  createdVia               String?
  // Exact payment-to-subscription attribution: the raw Finix transfer
  // payload's own `subscription` reference (not inferred from donor/amount/
  // instrument matching). Populated going forward by the TRANSFER webhook
  // handler, and backfillable from already-stored rawJsonRedacted for
  // historical rows with zero new Finix API calls. A transfer with
  // createdVia === "SUBSCRIPTION" but a null finixSubscriptionId has no
  // verified relationship and must be labeled "Unattributed Recurring
  // Candidate" rather than counted in confirmed recurring totals.
  finixSubscriptionId      String?
  tagsJson                 Json?
  rawJsonRedacted          Json?
  createdAtFinix           DateTime?
  updatedAtFinix           DateTime?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt
  lastSyncedAt             DateTime?
  // Set by the payment-reconciliation fallback (see paymentReconciliation.ts)
  // whenever it re-fetches this transfer from Finix directly — distinct from
  // lastSyncedAt, which is also touched by ordinary webhook processing.
  lastReconciledAt         DateTime?

  @@index([churchId, finixSubscriptionId])
}

model FinixRefundOrReversal {
  id                      String    @id @default(cuid())
  churchId                String?
  refundRequestId         String?
